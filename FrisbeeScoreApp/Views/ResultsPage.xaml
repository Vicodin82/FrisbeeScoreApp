<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="FrisbeeScoreApp.Views.ResultsPage"
             Title="Tulokset">

    <Grid Padding="20" RowDefinitions="Auto,Auto,*,Auto,*" RowSpacing="12">

        <!-- Otsikko -->
        <Label Grid.Row="0"
               Text="Tulokset"
               FontSize="24"
               FontAttributes="Bold"
               HorizontalOptions="Center" />

        <!-- Radan valinta top 5:lle -->
        <Picker Grid.Row="1"
                x:Name="CoursePicker"
                Title="Valitse rata Top 5 -listaan"
                ItemDisplayBinding="{Binding Name}"
                SelectedIndexChanged="OnCourseSelectedChanged" />

        <!-- Top 5 -->
        <Frame Grid.Row="2" Padding="12" CornerRadius="12">
            <VerticalStackLayout Spacing="10">
                <Label Text="Top 5 tällä radalla"
                       FontSize="18"
                       FontAttributes="Bold" />

                <CollectionView x:Name="TopResultsList">
                    <CollectionView.ItemTemplate>
                        <DataTemplate>
                            <Frame Padding="10" Margin="0,4" CornerRadius="10">
                                <VerticalStackLayout Spacing="4">
                                    <Label Text="{Binding CourseName}"
                                           FontAttributes="Bold" />
                                    <Label Text="{Binding DatePlayed, StringFormat='Päivä: {0:dd.MM.yyyy HH:mm}'}" />
                                    <Label Text="{Binding TotalThrows, StringFormat='Heitot: {0}'}" />
                                    <Label Text="{Binding TotalVsPar, StringFormat='Pariin: {0:+#;-#;0}'}" />
                                </VerticalStackLayout>
                            </Frame>
                        </DataTemplate>
                    </CollectionView.ItemTemplate>
                </CollectionView>
            </VerticalStackLayout>
        </Frame>

        <!-- Kaikki kierrokset otsikko -->
        <Label Grid.Row="3"
               Text="Kaikki kierrokset"
               FontSize="18"
               FontAttributes="Bold" />

        <!-- Historia -->
        <CollectionView Grid.Row="4" x:Name="ResultsList">
            <CollectionView.ItemTemplate>
                <DataTemplate>
                    <Frame Padding="12" Margin="0,5" CornerRadius="12">
                        <VerticalStackLayout Spacing="4">
                            <Label Text="{Binding CourseName}"
                                   FontSize="17"
                                   FontAttributes="Bold" />
                            <Label Text="{Binding DatePlayed, StringFormat='Päivä: {0:dd.MM.yyyy HH:mm}'}" />
                            <Label Text="{Binding TotalThrows, StringFormat='Heitot: {0}'}" />
                            <Label Text="{Binding TotalVsPar, StringFormat='Pariin: {0:+#;-#;0}'}" />
                        </VerticalStackLayout>
                    </Frame>
                </DataTemplate>
            </CollectionView.ItemTemplate>
        </CollectionView>

    </Grid>
</ContentPage>