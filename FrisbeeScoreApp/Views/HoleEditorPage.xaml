<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="FrisbeeScoreApp.Views.HoleEditorPage"
             Title="Väylät">

    <ScrollView>
        <VerticalStackLayout Padding="20" Spacing="15">

            <!-- Radan nimi -->
            <Label x:Name="CourseNameLabel"
                   Text="Rata"
                   FontSize="24"
                   FontAttributes="Bold"
                   HorizontalOptions="Center" />

            <!-- Väylälista -->
            <CollectionView x:Name="HolesList">
                <CollectionView.ItemTemplate>
                    <DataTemplate>
                        <Frame Padding="10" Margin="0,5">
                            <Grid ColumnDefinitions="*,Auto" ColumnSpacing="15">

                                <!-- Väylän numero -->
                                <Label Grid.Column="0"
                                       VerticalOptions="Center"
                                       Text="{Binding HoleNumber, StringFormat='Väylä {0}'}" />

                                <!-- Par-kenttä -->
                                <Entry Grid.Column="1"
                                       WidthRequest="80"
                                       Keyboard="Numeric"
                                       Text="{Binding Par}" />
                            </Grid>
                        </Frame>
                    </DataTemplate>
                </CollectionView.ItemTemplate>
            </CollectionView>

            <!-- Tallenna -->
            <Button Text="Tallenna väylät"
                    Clicked="OnSaveClicked" />

        </VerticalStackLayout>
    </ScrollView>
</ContentPage>